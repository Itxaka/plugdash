#!/usr/bin/env python3
"""plugdash external plugin: track a variable's value in a file on a git branch.

This is an example external plugin. It demonstrates the plugdash plugin protocol
in a language other than Go: the dashboard runs this executable with `describe`
to learn its config schema, and with `run` (config JSON on stdin) to fetch a
result. See docs/PLUGINS.md for the protocol.

Use case: watch the value of some variable in a file on a repo's branch — e.g.
track a pinned dependency version across repos at a glance.

No third-party dependencies; uses only the Python standard library.
"""
import json
import re
import sys
import urllib.request
import urllib.error

META = {
    "id": "file-version",
    "name": "File Value Watcher",
    "description": "Track a variable's value in a file on a GitHub repo branch (e.g. a pinned dependency).",
    # Files change rarely; check hourly. The dashboard treats this as a floor.
    "refresh_interval_seconds": 3600,
    "schema": [
        {"key": "repo", "label": "Repository", "type": "string", "required": True,
         "placeholder": "owner/repo", "help": "GitHub repository as owner/repo."},
        {"key": "ref", "label": "Branch or tag", "type": "string",
         "placeholder": "main", "help": "Branch or tag to read from (default: main)."},
        {"key": "path", "label": "File path", "type": "string", "required": True,
         "placeholder": "go.mod", "help": "Path to the file within the repo."},
        {"key": "key", "label": "Variable name", "type": "string", "required": True,
         "placeholder": "VERSION", "help": "Name to the left of a `=` or `:` whose value is reported."},
    ],
}


def fail(msg):
    """Report an error per the protocol: message on stderr, non-zero exit."""
    print(msg, file=sys.stderr)
    sys.exit(1)


def run():
    cfg = json.load(sys.stdin)
    repo = (cfg.get("repo") or "").strip().removeprefix("https://github.com/").strip("/")
    ref = (cfg.get("ref") or "main").strip()
    path = (cfg.get("path") or "").strip().lstrip("/")
    key = (cfg.get("key") or "").strip()
    if not repo or not path or not key:
        fail("repo, path and key are required")

    url = f"https://raw.githubusercontent.com/{repo}/{ref}/{path}"
    req = urllib.request.Request(url, headers={"User-Agent": "plugdash-fileversion"})
    try:
        with urllib.request.urlopen(req, timeout=15) as resp:
            body = resp.read(2_000_000).decode("utf-8", "replace")
    except urllib.error.HTTPError as e:
        fail(f"fetch {url}: HTTP {e.code}")
    except Exception as e:  # noqa: BLE001 - any fetch failure is a plugin error
        fail(f"fetch {url}: {e}")

    # Find the first line `key = value`, `key: value`, or space-delimited
    # `key value` (e.g. the `go 1.22` directive in a go.mod).
    k = re.escape(key)
    m = re.search(r"^\s*" + k + r"\s*[:=]\s*(.+?)\s*$", body, re.MULTILINE)
    if not m:
        m = re.search(r"^\s*" + k + r"\s+(.+?)\s*$", body, re.MULTILINE)
    label = f"{repo}@{ref} · {path} · {key}"
    if not m:
        result = {"visualization": "stat",
                  "title": label,
                  "data": {"value": "not found", "label": label, "status": "error"}}
    else:
        value = m.group(1).strip().strip('"').strip("'").rstrip(",")
        result = {"visualization": "stat",
                  "title": label,
                  "data": {"value": value, "label": label, "status": "ok"}}
    json.dump(result, sys.stdout)


def main():
    cmd = sys.argv[1] if len(sys.argv) > 1 else ""
    if cmd == "describe":
        json.dump(META, sys.stdout)
    elif cmd == "run":
        run()
    else:
        fail(f"unknown command {cmd!r}; expected 'describe' or 'run'")


if __name__ == "__main__":
    main()
