#!/usr/bin/env python3
"""Minimal example of a plugdash EXTERNAL plugin.

An external plugin is any executable named `plugdash-plugin-*` placed in the
plugins directory. plugdash discovers it and speaks a tiny stdio protocol:

  describe : print metadata JSON (id, name, description, refresh, config schema)
  run      : read the tracker's config JSON on stdin, print a Result JSON

This sample takes no real input and just reports the current UTC time as a
"stat" widget — enough to show the protocol end to end. It only uses the Python
standard library. See docs/PLUGINS.md for the full contract and the available
visualizations (list / table / checklist / stat / timeseries).
"""
import datetime
import json
import sys

META = {
    "id": "example",
    "name": "Example (clock)",
    "description": "A minimal external-plugin sample: shows the current UTC time.",
    "refresh_interval_seconds": 30,
    "schema": [
        {"key": "label", "label": "Label", "type": "string",
         "placeholder": "UTC now", "help": "Text shown under the value."},
    ],
}


def run():
    cfg = json.load(sys.stdin) if not sys.stdin.isatty() else {}
    label = (cfg.get("label") or "UTC now").strip()
    now = datetime.datetime.now(datetime.timezone.utc).strftime("%H:%M:%S")
    json.dump({
        "visualization": "stat",
        "title": "Example plugin",
        "data": {"value": now, "label": label, "status": "ok"},
    }, sys.stdout)


def main():
    cmd = sys.argv[1] if len(sys.argv) > 1 else ""
    if cmd == "describe":
        json.dump(META, sys.stdout)
    elif cmd == "run":
        run()
    else:
        print(f"unknown command {cmd!r}; expected 'describe' or 'run'", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
